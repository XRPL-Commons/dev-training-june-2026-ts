{
  "name": "XRPL Academy TypeScript",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20",

  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },

  "onCreateCommand": "bash .devcontainer/setup.sh",
  "postStartCommand": "npx ts-node scripts/mint-wallets.ts && $HOME/.local/bin/xrpl-start-progress-watcher \"$PWD\"",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vsliveshare.vsliveshare",
        "ms-vscode.vscode-typescript-next",
        "formulahendry.code-runner"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.fontSize": 14,
        "terminal.integrated.defaultProfile.linux": "bash",
        "code-runner.runInTerminal": true,
        "typescript.tsdk": "exercises/typescript/node_modules/typescript/lib"
      }
    }
  },

  "forwardPorts": [3000, 5000, 8080],

  "remoteEnv": {
    "XRPL_NETWORK": "wss://s.altnet.rippletest.net:51233",
    "XRPL_FAUCET": "https://faucet.altnet.rippletest.net/accounts"
  }
}
